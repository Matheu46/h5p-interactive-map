[
  {
    "name": "iconSettings",
    "type": "group",
    "label": "Custom Icon Settings",
    "description": "Custom Icon Settings",
    "optional": true,
    "fields": [
      {
        "name": "dummySummary",
        "type": "text",
        "label": "Icon name",
        "default": "",
        "optional": true
      },
      {
        "name": "icon",
        "type": "file",
        "label": "Point icon",
        "description": "Upload a custom icon for the map points",
        "optional": true,
        "mimetypes": ["image/png", "image/jpeg", "image/svg+xml"],
        "maxSize": 512000
      },
      {
        "name": "iconSize",
        "type": "text",
        "label": "Icon size",
        "description": "Define the icon size in format: width,height (e.g., 25,41)",
        "default": "25,41"
      },
      {
        "name": "iconAnchor",
        "type": "text",
        "label": "Icon anchor point",
        "description": "Define the icon anchor point (x,y) (e.g., 12,41)",
        "default": "12,41"
      },
      {
        "name": "popupAnchor",
        "type": "text",
        "label": "Popup anchor point",
        "description": "Define the popup anchor point (x,y) (e.g., 1,-34)",
        "default": "1,-34"
      },
      {
        "name": "shadowUrl",
        "type": "file",
        "label": "Shadow icon",
        "description": "Upload an icon for the marker shadow",
        "optional": true,
        "mimetypes": ["image/png", "image/jpeg", "image/svg+xml"],
        "maxSize": 512000
      },
      {
        "name": "shadowSize",
        "type": "text",
        "label": "Shadow size",
        "description": "Define the shadow size in format: width,height (e.g., 41,41)",
        "default": "41,41"
      }
    ]
  },
  {
    "name": "restrictNavigation",
    "type": "boolean",
    "label": "Restrict map navigation",
    "description": "Lock the map view so the user cannot pan away from the area containing the markers.",
    "default": false
  },
  {
    "name": "mapPoints",
    "type": "list",
    "label": "Map points",
    "entity": "Location",
    "field": {
      "name": "point",
      "type": "group",
      "label": "Map Point",
      "fields": [
        {
          "name": "title",
          "type": "text",
          "label": "Point Title",
          "description": "Location name"
        },
        {
          "name": "location",
          "type": "group",
          "label": "Point Coordinates",
          "widget": "mapPointSelector",
          "fields": [
            {
              "name": "latitude",
              "type": "number",
              "label": "Latitude",
              "decimals": 6
            },
            {
              "name": "longitude",
              "type": "number",
              "label": "Longitude",
              "decimals": 6
            }
          ]
        },
        {
          "name": "interactiveContent",
          "type": "library",
          "label": "Interactive content",
          "description": "H5P library displayed in the modal when clicking the point",
          "optional": true,
          "options": [
            "H5P.AdvancedText 1.1",
            "H5P.Image 1.1",
            "H5P.Video 1.6",
            "H5P.MultiChoice 1.16",
            "H5P.TrueFalse 1.8"
          ],
          "importance": "high"
        }
      ]      
    }
  },
  {
    "name": "l10n",
    "type": "group",
    "common": true,
    "label": "Translate user interface",
    "fields": [
      {
        "name": "searchPlaceholder",
        "type": "text",
        "label": "Search placeholder",
        "default": "Type the location name"
      },
      {
        "name": "resetViewButton",
        "type": "text",
        "label": "Reset view button",
        "default": "View all locations"
      },
      {
        "name": "modalAriaLabel",
        "type": "text",
        "label": "Modal aria label",
        "default": "Interactive map content"
      },
      {
        "name": "closeButtonAriaLabel",
        "type": "text",
        "label": "Close button aria label",
        "default": "Close"
      },
      {
        "name": "noInteractiveContent",
        "type": "text",
        "label": "No interactive content message",
        "default": "No interactive content has been configured for this point."
      },
      {
        "name": "noResultsMessage",
        "type": "text",
        "label": "No results message",
        "default": "No locations found."
      },
      {
        "name": "layerMapDefault",
        "type": "text",
        "label": "Default Map Layer Name",
        "default": "Map (Default)"
      },
      {
        "name": "layerSatellite",
        "type": "text",
        "label": "Satellite Layer Name",
        "default": "Satellite"
      },
      {
        "name": "layerTopographic",
        "type": "text",
        "label": "Topographic Layer Name",
        "default": "Topographic"
      }
    ]
  }
]
